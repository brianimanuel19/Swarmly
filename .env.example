# Claude / Anthropic API
ANTHROPIC_API_KEY=sk-ant-api03-...

# MySQL (mysql2)
DB_HOST=localhost
DB_PORT=3306
DB_USER=swarmly
DB_PASSWORD=your_password
DB_NAME=swarmly

# Slack App (Socket Mode)
SLACK_BOT_TOKEN=xoxb-...
SLACK_SIGNING_SECRET=...
SLACK_APP_TOKEN=xapp-...
SLACK_LOBBY_CHANNEL=C0XXXXXXX
SLACK_BOT_USER_ID=U0XXXXXXX

# Jira
JIRA_BASE_URL=https://yourcompany.atlassian.net
JIRA_EMAIL=your@email.com
JIRA_API_TOKEN=...
# JIRA_PROJECT_KEY is OPTIONAL — Swarmly auto-creates a new Jira project per run.
# Set it only if you want a fallback/default project key.
# JIRA_PROJECT_KEY=SWM

# GitHub
GITHUB_TOKEN=ghp_...
GITHUB_OWNER=your-username   # your GitHub username or org name
# GITHUB_REPO is OPTIONAL — Swarmly auto-creates a new GitHub repo per run.
# Set it only if you want a fallback/default repo for legacy operations.
# GITHUB_REPO=swarmly-projects

# Dashboard
DASHBOARD_PORT=3001
JWT_SECRET=change-this-to-a-random-secret-in-production

# Docker (usually no need to change)
DOCKER_SOCKET=/var/run/docker.sock
